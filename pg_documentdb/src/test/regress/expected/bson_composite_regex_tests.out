SELECT document FROM documentdb_api_catalog.bson_aggregation_find('regex_db', :'q1'::bson);
                              document                               
---------------------------------------------------------------------
 { "_id" : { "$numberInt" : "12" }, "a" : "abc\x7Fdef", "b" : true }
(1 row)

