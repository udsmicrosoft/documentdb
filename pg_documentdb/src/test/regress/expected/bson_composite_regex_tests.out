 { "_id" : { "$numberInt" : "2" }, "a" : "string2", "b" : true }
 { "_id" : { "$numberInt" : "3" }, "a" : "string123", "b" : false }
(3 rows)

-- Insert data with tilde (~, 0x7E) for boundary testing
