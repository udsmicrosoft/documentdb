-- === EXPLAIN plan tests showing index bounds ===
set documentdb.enableExtendedExplainPlans to on;
-- optimized: ^string should show tight bounds [string, strinh)
SELECT documentdb_test_helpers.run_explain_and_trim($cmd$
    EXPLAIN (COSTS OFF, ANALYZE ON, SUMMARY OFF, TIMING OFF, BUFFERS OFF)
    SELECT document FROM bson_aggregation_find('regex_db', '{ "find": "regex_coll", "filter": { "a": { "$regex": "^string" } } }')
$cmd$);
                                                                                                             run_explain_and_trim                                                                                                              
-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Custom Scan (DocumentDBApiExplainQueryScan) (actual rows=3 loops=1)
   namespaceName: regex_db.regex_coll
   indexName: idx_a_1_b_1
   indexKey: {"a": 1,"b": 1}
   isMultiKey: false
   hasTruncation: true
   indexBounds: ["a": ["string", "strinh"), "b": (MinKey, MaxKey)], ["a": [{ "$regularExpression" : { "pattern" : "^string", "options" : "" } }, { "$regularExpression" : { "pattern" : "^string", "options" : "" } }], "b": (MinKey, MaxKey)]
   ->  Bitmap Heap Scan on documents_1201 collection (actual rows=3 loops=1)
         Recheck Cond: (document @~ '{ "a" : { "$regularExpression" : { "pattern" : "^string", "options" : "" } } }'::bson)
         Rows Removed by Index Recheck: 2
         Heap Blocks: exact=1
         ->  Bitmap Index Scan on idx_a_1_b_1 (actual rows=5 loops=1)
               Index Cond: (document @~ '{ "a" : { "$regularExpression" : { "pattern" : "^string", "options" : "" } } }'::bson)
(13 rows)

