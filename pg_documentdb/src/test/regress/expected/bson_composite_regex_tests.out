 { "_id" : { "$numberInt" : "2" }, "a" : "string2", "b" : true }
 { "_id" : { "$numberInt" : "3" }, "a" : "string123", "b" : false }
 { "_id" : { "$numberInt" : "4" }, "a" : "strong", "b" : true }
 { "_id" : { "$numberInt" : "5" }, "a" : "abc", "b" : true }
 { "_id" : { "$numberInt" : "6" }, "a" : "abcd", "b" : true }
 { "_id" : { "$numberInt" : "7" }, "a" : "abce", "b" : false }
 { "_id" : { "$numberInt" : "8" }, "a" : "xyz", "b" : true }
 { "_id" : { "$numberInt" : "15" }, "a" : "abc|def", "b" : true }
 { "_id" : { "$numberInt" : "16" }, "a" : "abc\\dog", "b" : true }
 { "_id" : { "$numberInt" : "17" }, "a" : "abd123", "b" : true }
 { "_id" : { "$numberInt" : "18" }, "a" : "ab5", "b" : true }
(12 rows)

-- ^( (group start right after anchor): no literal prefix
SELECT document FROM documentdb_api_catalog.bson_aggregation_find('regex_db', '{ "find": "regex_coll", "filter": { "a": { "$regex": "^(string)" } } }');
                              document                              
--------------------------------------------------------------------
