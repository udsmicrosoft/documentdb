                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

-- prefix ending with ~ (0x7E): upper bound increments to DEL (0x7F)
SELECT document FROM documentdb_api_catalog.bson_aggregation_find('regex_db', '{ "find": "regex_coll", "filter": { "a": { "$regex": "^~" } } }');
                            document                             
-----------------------------------------------------------------
