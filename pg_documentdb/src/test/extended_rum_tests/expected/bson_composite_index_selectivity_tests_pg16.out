         Presorted Key: (bson_orderby(document, '{ "groupId" : { "$numberInt" : "1" } }'::bson))
         ->  Custom Scan (DocumentDBApiExplainQueryScan)
               namespaceName: comp_idb.generic_selectiviity_coll
               indexName: idx_ownerId_groupId_state_flag_id
               indexKey: {"_id.ownerId": 1,"groupId": 1,"state": 1,"flag": 1,"_id": 1}
               isMultiKey: false
               indexBounds: ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-0", "group-0"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-1", "group-1"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-2", "group-2"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-3", "group-3"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-4", "group-4"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-5", "group-5"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-6", "group-6"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-7", "group-7"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-8", "group-8"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-9", "group-9"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)], ["_id.ownerId": ["owner-3", "owner-3"], "groupId": ["group-10", "group-10"], "state": (MinKey, MaxKey), "flag": [false, false], "_id": (MinKey, MaxKey)]
